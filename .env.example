# Stage selects adapters (queue/storage/scheduler). Nothing else reads it.
STAGE=local
PORT=3000

# For host runs use localhost; inside docker compose the app overrides this to `db`.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/hashtag_tracker

# Meta credentials. If META_ACCESS_TOKEN is empty, the app still boots and serves
# the read API; syncs log a skip message instead of calling Meta.
META_ACCESS_TOKEN=
META_USER_ID=

# Hashtag to track (default: matcha)
HASHTAG=matcha

# Recent-media sync schedule (local/node-cron only). Default: every 3 hours.
SYNC_CRON=0 */3 * * *

# Local storage adapter
MEDIA_DIR=./media
PUBLIC_BASE_URL=http://localhost:3000
